{
    "linux": {
        "all": {
            "symlink": {
                "~": [
                    {
                        "fake": "~/.oh-my-bash",
                        "real": ".dotfiles/bash/.oh-my-bash"
                    },
                    {
                        "fake": "~/.config/tmux",
                        "real": ".dotfiles/tmux/tmux"
                    }
                ],
                "~/.config": [
                    {
                        "fake": "~/.config/lazygit",
                        "real": "../.dotfiles/git/lazygit"
                    }
                ],
                "~/.dotfiles": [
                    {
                        "fake": "~/.config/starship.toml",
                        "real": "bash/starship.toml"
                    },
                    {
                        "fake": "~/.config/flk/flk-store.json",
                        "real": "flk-store.json"
                    },
                    {
                        "fake": "~/.config/fastfetch",
                        "real": "fastfetch"
                    },
                    {
                        "fake": "~/.config/fish",
                        "real": "fish"
                    }
                ],
                "~/.dotfiles/bash": [
                    {
                        "fake": "~/.bashrc",
                        "real": ".bashrc"
                    }
                ],
                "~/.dotfiles/tmux": [
                    {
                        "fake": "~/.tmux.conf",
                        "real": ".tmux.conf"
                    }
                ]
            }
        }
    }
}